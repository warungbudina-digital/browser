{
  "name": "full-tool-browser",
  "version": "0.2.0",
  "description": "Standalone OpenClaw-like browser control surface with SSRF policy and remote CDP profile management.",
  "type": "module",
  "bin": {
    "full-tool-browser": "./src/cli.js"
  },
  "scripts": {
    "dev": "node ./src/index.js",
    "start": "node ./src/index.js",
