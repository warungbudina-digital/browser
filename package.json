  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "bullmq": "^5.38.0",
    "fastify": "^5.0.0",
    "mqtt": "^5.10.1",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "patchright": "^1.54.0",
    "zod": "^3.23.8"
  }
}
