# =============================================================================
# .env.example — Browser VPS (Scraper)
# Salin ke .env dan isi nilainya: cp .env.example .env
# Atau jalankan setup.sh yang akan membuat .env secara interaktif.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=ganti_dengan_password_kuat
DB_ENABLED=true

# ── WireGuard / CHR VPS ───────────────────────────────────────────────────────
# IP publik VPS CHR — hanya untuk referensi setup WireGuard
CHR_PUBLIC_IP=

# ── MQTT (publish hasil scraping ke CHR broker) ───────────────────────────────
MQTT_ENABLED=false
MQTT_BROKER_URL=mqtt://10.10.0.1:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=scraper/results

# ── API Security ──────────────────────────────────────────────────────────────
# Kunci yang dikirim oleh VPS CHR di setiap request ke Scraper API
# Harus sama dengan BROWSER_API_KEY di docker-compose.yml VPS CHR
# Generate: openssl rand -hex 32
API_KEY=

# ── CHR → Scraper auth (untuk referensi konfigurasi VPS CHR) ─────────────────
# Set nilai ini di docker-compose.yml VPS CHR:
#   grpc-server:
#     environment:
#       BROWSER_API_KEY=<nilai API_KEY di atas>
# BROWSER_API_KEY=   ← variabel ini ada di VPS CHR, bukan di sini

# ── Browser Pool ──────────────────────────────────────────────────────────────
BROWSER_POOL_SIZE=3

# ── TikTok Growth OS Bridge ────────────────────────────────────────────────────
# Ketika true, hasil scrape TikTok otomatis di-log ke analytics.json skill
# tiktok-growth-os (skill/tiktok-growth-os/), supaya bisa dianalisis via
# scripts/analyze_patterns.py di HOST (bukan di dalam container).
TIKTOK_GROWTH_OS_BRIDGE_ENABLED=false
# Path DI DALAM CONTAINER tempat analytics.json ditulis — harus di-bind-mount
# ke direktori HOST yang sama dengan storage.py's BASE_DIR
# (~/.openclaw/workspace/memory/tiktok milik user yang menjalankan analyze_patterns.py).
TIKTOK_GROWTH_OS_MEMORY_DIR=/data/skill-memory/tiktok
# Path di HOST yang di-bind-mount ke TIKTOK_GROWTH_OS_MEMORY_DIR di atas.
# HARUS sama persis dengan ~/.openclaw/workspace/memory/tiktok milik user yang
# akan menjalankan analyze_patterns.py secara manual di host (docker-compose
# tidak meng-expand "~", isi path absolut).
TIKTOK_GROWTH_OS_HOST_DIR=
