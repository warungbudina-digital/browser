[Interface]
# VPS CHR — WireGuard server endpoint
# IP tunnel ini: 10.10.0.1/24
Address = 10.10.0.1/24
ListenPort = 51820
PrivateKey = REPLACE_WITH_CHR_PRIVATE_KEY

# IP forwarding + iptables rules
# Ganti ens3 sesuai interface utama VPS (eth0 / ens3 / ens5)
# Ganti br-fb4f86860bbf sesuai nama bridge docker network "mikrotik-net":
#   docker network inspect mikrotik-net --format '{{.Id}}' | cut -c1-12
#   -> nama bridge = "br-<12 char id>"
PostUp   = sysctl -w net.ipv4.ip_forward=1
PostUp   = iptables -A FORWARD -i wg0 -j ACCEPT
PostUp   = iptables -A FORWARD -o wg0 -j ACCEPT
PostUp   = iptables -t nat -A POSTROUTING -s 10.10.0.0/24 -o ens3 -j MASQUERADE
# Docker drops semua forwarded traffic wg0->bridge yang tidak cocok dengan
# published-port rule miliknya sendiri (lihat README.md di folder ini).
# Bypass itu di DOCKER-USER, yang dievaluasi SEBELUM chain DOCKER-FORWARD milik Docker.
PostUp   = iptables -I DOCKER-USER 1 -i wg0 -o br-fb4f86860bbf -j ACCEPT
PostUp   = iptables -I DOCKER-USER 2 -i br-fb4f86860bbf -o wg0 -j ACCEPT
# MASQUERADE supaya reply dari container ter-rewrite balik dengan benar lewat conntrack
PostUp   = iptables -t nat -A POSTROUTING -s 10.10.0.0/24 -d 172.20.0.0/24 -j MASQUERADE
# DNS dari scraper VPS -> di-forward ke PiHole container (172.20.0.6)
PostUp   = iptables -t nat -A PREROUTING -i wg0 -p udp --dport 53 -j DNAT --to-destination 172.20.0.6:53
PostUp   = iptables -t nat -A PREROUTING -i wg0 -p tcp --dport 53 -j DNAT --to-destination 172.20.0.6:53
# MQTT dari scraper VPS -> di-forward ke Mosquitto container (172.20.0.7)
PostUp   = iptables -t nat -A PREROUTING -i wg0 -p tcp --dport 1883 -j DNAT --to-destination 172.20.0.7:1883
PostUp   = iptables -t nat -A PREROUTING -i wg0 -p tcp --dport 9001 -j DNAT --to-destination 172.20.0.7:9001

PostDown = iptables -D FORWARD -i wg0 -j ACCEPT
PostDown = iptables -D FORWARD -o wg0 -j ACCEPT
PostDown = iptables -t nat -D POSTROUTING -s 10.10.0.0/24 -o ens3 -j MASQUERADE
PostDown = iptables -D DOCKER-USER -i wg0 -o br-fb4f86860bbf -j ACCEPT
PostDown = iptables -D DOCKER-USER -i br-fb4f86860bbf -o wg0 -j ACCEPT
PostDown = iptables -t nat -D POSTROUTING -s 10.10.0.0/24 -d 172.20.0.0/24 -j MASQUERADE
PostDown = iptables -t nat -D PREROUTING -i wg0 -p udp --dport 53 -j DNAT --to-destination 172.20.0.6:53
PostDown = iptables -t nat -D PREROUTING -i wg0 -p tcp --dport 53 -j DNAT --to-destination 172.20.0.6:53
PostDown = iptables -t nat -D PREROUTING -i wg0 -p tcp --dport 1883 -j DNAT --to-destination 172.20.0.7:1883
PostDown = iptables -t nat -D PREROUTING -i wg0 -p tcp --dport 9001 -j DNAT --to-destination 172.20.0.7:9001

[Peer]
# VPS Scraper (full-tool-browser)
PublicKey = REPLACE_WITH_SCRAPER_PUBLIC_KEY
AllowedIPs = 10.10.0.2/32
# PersistentKeepalive tidak diperlukan di server side
